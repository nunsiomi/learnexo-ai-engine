# LearNEXO frontend — environment variables
#
# Copy this file to .env and fill in values for your environment.
# .env is gitignored and must never be committed.
#
# VITE_API_URL — base URL of the LearNEXO FastAPI backend.
# Override this per-environment:
#   Local dev  : http://localhost:8000  (uvicorn default)
#   Staging    : https://your-staging-backend.example.com
#   Production : https://your-production-backend.example.com
#
# The backend's ALLOWED_ORIGINS (main.py) must include this frontend's origin.
VITE_API_URL=http://localhost:8000

# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY — Supabase project credentials,
# used for sign-in/sign-up and storing profile + roadmap progress.
# Find both under Supabase dashboard → Project Settings → API.
# The anon key is safe to expose client-side; access is enforced by the
# Row Level Security policies on the profiles/topic_progress tables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
