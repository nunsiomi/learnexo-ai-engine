# Required: Your Groq API key (powers all AI content generation)
# Get one free at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Required for /videos endpoint: YouTube Data API v3 key
# Get one at https://console.cloud.google.com → Enable "YouTube Data API v3"
YOUTUBE_API_KEY=your_youtube_key_here

# Optional: Override the default AI model
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Server port (defaults to 8000)
# PORT=8000

# Optional: extra CORS origin(s) to allow, comma-separated. Used in
# production to add the deployed frontend's URL (e.g. Render sets this
# automatically via render.yaml). Not needed for local dev — localhost
# origins are always allowed.
# ADDITIONAL_ALLOWED_ORIGINS=https://your-frontend.onrender.com
