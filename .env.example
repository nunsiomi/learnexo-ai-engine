# Required: Your Groq API key (powers all AI content generation)
# Get one free at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Required for /videos endpoint: YouTube Data API v3 key
# Get one at https://console.cloud.google.com → Enable "YouTube Data API v3"
YOUTUBE_API_KEY=your_youtube_key_here

# Optional: Override the default AI model
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Server port (defaults to 8000)
# PORT=8000
